# Database – Neon (free tier) or local PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# App URL (e.g., https://mishkei-dan.vercel.app or http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# next-auth secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"

# Approval token secret (generate with: openssl rand -base64 32)
APPROVAL_TOKEN_SECRET="your-approval-secret-here"

# Resend API key (free tier: 3,000 emails/month)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AUTH_RESEND_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email sender address (must be verified in Resend)
EMAIL_FROM="noreply@yourdomain.co.il"
