// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  requester
  signatory
}

enum OrderStatus {
  draft
  pending_signatory
  rejected_signatory
  pending_admin
  approved
  cancelled
}

enum Holiday {
  rosh_hashana
  passover
  other
}

// ─── Core Models ────────────────────────────────────────────────────────────

model Organization {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(200)
  parentOrg     String?  @db.VarChar(50)
  code          String?  @unique @db.VarChar(50)
  contactEmail  String?  @db.VarChar(255)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users  User[]
  orders Order[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique @db.VarChar(255)
  fullName       String    @db.VarChar(200)
  phone          String?   @db.VarChar(20)
  role           UserRole
  organizationId String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization      Organization? @relation(fields: [organizationId], references: [id])
  ordersAsRequester Order[]       @relation("Requester")
  ordersAsSignatory Order[]       @relation("Signatory")
  adminApprovals    Order[]       @relation("AdminReviewer")
  auditLogs         AuditLog[]
  settingsUpdates   SystemSetting[]

  // next-auth
  accounts Account[]
  sessions Session[]

  @@index([organizationId])
  @@map("users")
}

model CardType {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(200)
  nameHe        String   @db.VarChar(200)
  description   String?  @db.Text
  discountPct   Decimal  @db.Decimal(5, 2)
  minLoadAmount Decimal  @default(100) @db.Decimal(10, 2)
  maxLoadAmount Decimal  @default(1500) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems OrderItem[]

  @@map("card_types")
}

model OrderWindow {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(200)
  holiday       Holiday  @default(other)
  orderOpenAt   DateTime
  orderCloseAt  DateTime
  deliveryDate  DateTime @db.Date
  minOrderTotal Decimal  @default(2000) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]

  @@map("order_windows")
}

model Order {
  id             String      @id @default(uuid())
  orderNumber    String      @unique @db.VarChar(50)
  organizationId String
  orderWindowId  String
  requesterId    String
  signatoryId    String?

  status OrderStatus @default(draft)

  totalCards     Int     @default(0)
  totalFaceValue Decimal @default(0) @db.Decimal(12, 2)
  totalPayable   Decimal @default(0) @db.Decimal(12, 2)

  termsAcceptedAt     DateTime?
  signatoryReviewedAt DateTime?
  signatoryComment    String?   @db.Text
  adminReviewedAt     DateTime?
  adminReviewedById   String?
  adminComment        String?   @db.Text

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  orderWindow     OrderWindow  @relation(fields: [orderWindowId], references: [id])
  requester       User         @relation("Requester", fields: [requesterId], references: [id])
  signatory       User?        @relation("Signatory", fields: [signatoryId], references: [id])
  adminReviewedBy User?        @relation("AdminReviewer", fields: [adminReviewedById], references: [id])
  items           OrderItem[]

  @@index([organizationId])
  @@index([orderWindowId])
  @@index([status])
  @@index([requesterId])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  cardTypeId     String
  quantity       Int
  loadAmount     Decimal  @db.Decimal(10, 2)
  discountPct    Decimal  @db.Decimal(5, 2)
  faceValueTotal Decimal  @db.Decimal(12, 2)
  payableTotal   Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cardType CardType @relation(fields: [cardTypeId], references: [id])

  @@unique([orderId, cardTypeId, loadAmount])
  @@index([orderId])
  @@map("order_items")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(100)
  value       Json
  description String?  @db.Text
  updatedById String?
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("system_settings")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String   @db.VarChar(100)
  entityId   String
  action     String   @db.VarChar(100)
  actorId    String?
  actorEmail String?  @db.VarChar(255)
  oldValue   Json?
  newValue   Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_log")
}

// ─── Next-Auth Models ────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model OtpCode {
  id          String   @id @default(cuid())
  email       String
  code        String   // 6-digit numeric code
  callbackUrl String   // next-auth magic link URL to redirect to after verification
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([email])
  @@map("otp_codes")
}
